# Server
PORT=5002
NODE_ENV=development

# SeloraX Platform (shared)
JWT_SECRET=your_selorax_jwt_secret

# MySQL (same DB as SeloraX)
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_PORT=3306

# BulkSMS (platform default provider)
SMS_API_ENDPOINT=
SMS_API_KEY=
SMS_API_SENDER_ID=

# EPS Payment Gateway
EPS_BASE_URL=https://pgapi.eps.com.bd
EPS_PG_URL=https://pg.eps.com.bd
EPS_MERCHANT_ID=
EPS_STORE_ID=
EPS_USERNAME=
EPS_PASSWORD=
EPS_HASH_KEY=

# App callback base URL
APP_BASE_URL=http://localhost:5002
# SeloraX dashboard URL (for redirects after payment)
DASHBOARD_URL=http://localhost:3000
